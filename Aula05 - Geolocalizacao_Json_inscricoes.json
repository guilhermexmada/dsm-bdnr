db.inscricoes.aggregate(
[
  {
  $geoNear: {
    near: {
      type: "Point",
      coordinates: [
          -47.948500,
          -24.378200
        ]
      },
    distanceField: "distancia",
    shperical: true
    }
  },
  {
    {$limit: 4
    }
  }
]
)

// buscar alunos em até 1km de distância
db.inscricoes.aggregate([
  {
    $geoNear:{
      near:{
        type:"Point",
        coordinates:[-47.929220, -24.389230],
        distanceField:"distancia",
        spherical:true,
        maxDistance:1000
      }
    }
  }
])

// converter a distância para quilômetros
db.inscricoes.aggregate([
  {
    $geoNear:{
      near:{
        type:"Point",
        coordinates:[-47.929220, -24.389230]},
        distanceField:"distancia",
        spherical:true,
        maxDistance:1000
      
    }
  },
  { $skip: 1},
  { $limit: 4},
  {
    $project:{  // seleciona e transforma campos
      nome: 1,  // 1 = incluir campo
      email: 1,
      distanciaMetros: 1,
      distanciaKm: {
        $divide: ["$distanciaMetros", 1000] // divide por 1000
      }
    }
  }
])

